{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "conversation"
  ],
  "properties": {
    "conversation": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "role",
          "content"
        ],
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "user",
              "assistant",
              "system",
              "tool"
            ]
          },
          "content": {
            "type": "string"
          }
        }
      }
    },
    "task_goal": {
      "type": "string"
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "type",
          "summary"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          }
        }
      }
    },
    "failed_attempts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "user_constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "current_state": {
      "type": "string"
    },
    "pending_tasks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
